# This is a TEMPLATE. The app copies it to `.env` on first run, and the Settings
# screen in the web app writes your values here. `.env` is gitignored and never
# leaves your computer — do NOT put real secrets in THIS template file.

# Google Gemini API key — each user enters their OWN in the app's first-run
# screen (or here). Get one free at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# The website you want to test.
BASE_URL=https://example.com

# Optional: a URL that logs you in (tests with requires_login start here).
# It may include a token/query string. Leave blank if your site needs no login.
# LOGIN_URL=

# Optional: extra standing instructions added to every test
# (e.g. "This is a mobile site. Dismiss any cookie banner first.").
# CONTEXT_HINT=

# Which Gemini model drives the tests (gemini-2.5-flash is fast + cheap;
# gemini-2.5-pro is slower but smarter).
LLM_MODEL=gemini-2.5-flash

# Output language for the report and the AI's result summaries: "th" or "en".
# (The web UI has its own ไทย/EN switcher; this is the CLI/default.)
OUTPUT_LANG=th

# Browser viewport. Defaults are a typical desktop size.
# For mobile testing try 390 x 844, scale 2, and a mobile USER_AGENT.
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800
DEVICE_SCALE=1
# USER_AGENT=

# Optional: restrict the agent to these domains (comma-separated). If blank,
# it's derived automatically from BASE_URL / LOGIN_URL.
# ALLOWED_DOMAINS=example.com,*.example.com
